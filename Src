function Hacks:silent_aim()
    if self.active.silent_aim then
        self.active.silent_aim = false
        if self.functions.silent_aim then
            self.functions.silent_aim()
            self.functions.silent_aim = nil
        end
        return false
    end
    
    self.active.silent_aim = true
    local running = true
    
    self.functions.silent_aim = function()
        running = false
        self.active.silent_aim = false
        self.functions.silent_aim = nil
    end
    
    coroutine.wrap(function()
        while running do
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local closest = nil
                    local closest_dist = math.huge
                    
                    for _, target in ipairs(Players:GetPlayers()) do
                        if target ~= LocalPlayer then
                            local target_char = target.Character
                            if target_char then
                                local target_hrp = target_char:FindFirstChild("HumanoidRootPart")
                                if target_hrp then
                                    local dist = (target_hrp.Position - hrp.Position).Magnitude
                                    if dist < closest_dist then
                                        closest = target_hrp
                                        closest_dist = dist
                                    end
                                end
                            end
                        end
                    end
                    
                    if closest then
                        local mouse = LocalPlayer:GetMouse()
                        if mouse then
                            local target_pos = closest.Position + Vector3.new(0, 2, 0)
                            mouse.TargetFilter = char
                        end
                    end
                end
            end
            task.wait(0.05)
        end
    end)()
    
    return self.functions.silent_aim
end

