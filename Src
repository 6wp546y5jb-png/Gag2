local Duplicator = {}

function Duplicator:duplicate_items(player, item_name, count)
    count = count or 1
    local duplicated = {}
    
    local inventory = player:FindFirstChild("Inventory")
    if not inventory then 
        inventory = player:FindFirstChild("Backpack")
    end
    if not inventory then return false end
    
    local item = inventory:FindFirstChild(item_name)
    if not item then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == item_name and obj:IsA("Tool") then
                item = obj
                break
            end
        end
    end
    
    if not item then return false end
    
    for i = 1, count do
        local duplicate = item:Clone()
        duplicate.Name = item_name .. "_" .. tostring(i)
        duplicate.Parent = inventory
        table.insert(duplicated, duplicate)
        
        if duplicate:IsA("Tool") and player.Character then
            duplicate.Parent = player.Character
        end
    end
    
    return duplicated
end

function Duplicator:duplicate_character(player, count)
    count = count or 1
    local clones = {}
    
    local char = player.Character
    if not char then return false end
    
    local original_pos = char.HumanoidRootPart.Position
    
    for i = 1, count do
        local clone = char:Clone()
        clone.Name = player.Name .. "_Clone_" .. tostring(i)
        clone.Parent = workspace
        
        local hrp = clone:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Position = original_pos + Vector3.new(
                math.random(-10, 10),
                0,
                math.random(-10, 10)
            )
            hrp.Anchored = false
        end
        
        local humanoid = clone:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = humanoid.WalkSpeed * 0.5
            humanoid.JumpPower = humanoid.JumpPower * 0.5
        end
        
        table.insert(clones, clone)
        
        coroutine.wrap(function()
            while clone and clone.Parent do
                local current_pos = char.HumanoidRootPart.Position
                if current_pos and hrp then
                    local offset = Vector3.new(
                        math.random(-5, 5),
                        0,
                        math.random(-5, 5)
                    )
                    hrp.Position = current_pos + offset
                end
                task.wait(0.05)
            end
        end)()
    end
    
    return clones
end

function Duplicator:duplicate_objects(object_type, count)
    count = count or 10
    local objects = {}
    local results = {}
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA(object_type) and not obj:IsA("Model") then
            table.insert(objects, obj)
        end
    end
    
    for _, obj in ipairs(objects) do
        for i = 1, count do
            local clone = obj:Clone()
            clone.Name = obj.Name .. "_dup_" .. tostring(i)
            clone.CFrame = obj.CFrame + CFrame.new(
                math.random(-20, 20),
                math.random(-20, 20),
                math.random(-20, 20)
            )
            clone.Parent = workspace
            table.insert(results, clone)
        end
    end
    
    return results
end

function Duplicator:duplicate_currency(player, amount)
    amount = amount or 1000
    
    local leaderstats = player:FindFirstChild("leaderstats")
    if not leaderstats then return false end
    
    local currency = leaderstats:FindFirstChild("Coins") or 
                     leaderstats:FindFirstChild("Cash") or
                     leaderstats:FindFirstChild("Money") or
                     leaderstats:FindFirstChild("Points")
    
    if not currency then return false end
    
    local original = currency.Value
    currency.Value = original + amount
    
    for _, other in ipairs(game.Players:GetPlayers()) do
        if other ~= player then
            local other_stats = other:FindFirstChild("leaderstats")
            if other_stats then
                local other_currency = other_stats:FindFirstChild(currency.Name)
                if other_currency then
                    other_currency.Value = other_currency.Value + amount
                end
            end
        end
    end
    
    return true
end

function Duplicator:duplicate_gui(gui_name, count)
    count = count or 5
    local results = {}
    
    local player_gui = game.Players.LocalPlayer.PlayerGui
    if not player_gui then return false end
    
    local gui = player_gui:FindFirstChild(gui_name)
    if not gui then
        for _, screen in ipairs(player_gui:GetChildren()) do
            if screen.Name == gui_name then
                gui = screen
                break
            end
        end
    end
    
    if not gui then return false end
    
    for i = 1, count do
        local clone = gui:Clone()
        clone.Name = gui_name .. "_" .. tostring(i)
        clone.Parent = player_gui
        table.insert(results, clone)
    end
    
    return results
end

function Duplicator:duplicate_script(script_name, count)
    count = count or 3
    local results = {}
    local found = {}
    
    for _, obj in ipairs(game:GetDescendants()) do
        if (obj:IsA("Script") or obj:IsA("LocalScript")) and obj.Name == script_name then
            table.insert(found, obj)
        end
    end
    
    for _, script in ipairs(found) do
        for i = 1, count do
            local clone = script:Clone()
            clone.Name = script.Name .. "_dup_" .. tostring(i)
            clone.Parent = script.Parent
            clone.Disabled = false
            table.insert(results, clone)
        end
    end
    
    return results
end

function Duplicator:duplicate(target, type, count)
    count = count or 1
    local results = {}
    
    if type == "item" then
        results = self:duplicate_items(target, count)
    elseif type == "character" then
        results = self:duplicate_character(target, count)
    elseif type == "object" then
        results = self:duplicate_objects(target, count)
    elseif type == "currency" then
        results = self:duplicate_currency(target, count)
    elseif type == "gui" then
        results = self:duplicate_gui(target, count)
    elseif type == "script" then
        results = self:duplicate_script(target, count)
    end
    
    return results
end

function Duplicator:start_infinite_duplication(type, interval)
    interval = interval or 0.5
    local running = true
    
    coroutine.wrap(function()
        while running do
            self:duplicate(game.Players.LocalPlayer, type, 1)
            task.wait(interval)
        end
    end)()
    
    return function() running = false end
end

function Duplicator:duplicate_to_all(item_name, count)
    local results = {}
    for _, player in ipairs(game.Players:GetPlayers()) do
        local result = self:duplicate_items(player, item_name, count)
        table.insert(results, {
            player = player.Name,
            success = result ~= false
        })
    end
    return results
end

