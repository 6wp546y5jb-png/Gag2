-- FPS Counter
local lastUpdate, frameCount = os.clock(), 0
RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1
    if os.clock() - lastUpdate >= 1 then
        fpsLabel.Text = "FPS: " .. frameCount
        frameCount, lastUpdate = 0, os.clock()
    end
    
    -- Hitbox Expander
    if _G.HitboxEnabled then
        pcall(function()
            for _, model in ipairs(workspace:GetChildren()) do
                if model:IsA("Model") and model.Name:match("^CLIENT_BALL_%d+$") then
                    local ball = model:FindFirstChild("Ball.001")
                    if not ball then
                        for _, p in ipairs(model:GetDescendants()) do
                            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                                ball = Instance.new("Part", model)
                                ball.Name = "Ball.001"
                                ball.Shape = Enum.PartType.Ball
                                ball.Size = Vector3.new(2, 2, 2) * _G.CurrentHitboxScale
                                ball.CFrame = p.CFrame
                                ball.Anchored = true
                                ball.CanCollide = false
                                ball.Transparency = 0.7
                                ball.Material = Enum.Material.ForceField
                                ball.Color = Color3.fromRGB(168, 85, 247)
                                break
                            end
                        end
                    elseif ball then
                        ball.Size = Vector3.new(2, 2, 2) * _G.CurrentHitboxScale
                    end
                end
            end
        end)
    end
    
    -- Air Movement
    if _G.AirMoveEnabled and humanoid and hrp then
        pcall(function()
            local state = humanoid:GetState()
            if state == Enum.HumanoidStateType.Freefall or state == Enum.HumanoidStateType.Jumping then
                local moveDir = humanoid.MoveDirection
                if moveDir.Magnitude > 0 then
                    hrp.Velocity = Vector3.new(moveDir.X * _G.AirMoveSpeed, hrp.Velocity.Y, moveDir.Z * _G.AirMoveSpeed)
                end
            end
        end)
    end
end)

-- Directional Jump
UIS.JumpRequest:Connect(function()
    if _G.DirectionalJump and humanoid and hrp then
        task.defer(function()
            task.wait(0.03)
            local dir = Vector3.new(Camera.CFrame.LookVector.X, 0, Camera.CFrame.LookVector.Z)
            if dir.Magnitude > 0 and hrp then
                hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + dir.Unit)
                humanoid.AutoRotate = false
            end
        end)
    elseif humanoid then
        humanoid.AutoRotate = true
    end
end)

