local Executor = {
    version = "3.2.1",
    features = {},
    loaded_scripts = {},
    active_hacks = {}
}

function Executor:execute(script_code)
    local success, result = pcall(function()
        local chunk = loadstring(script_code)
        if chunk then
            return chunk()
        end
        return nil
    end)
    return success, result
end

function Executor:inject_script(player, script_content)
    if not player or not script_content then
        return false
    end
    
    local success = pcall(function()
        local container = Instance.new("LocalScript")
        container.Name = "Injected_" .. os.time()
        container.Source = script_content
        container.Parent = player.Character or player
        container.Disabled = false
        
        for _, target in ipairs(game.Players:GetPlayers()) do
            if target ~= player then
                local copy = container:Clone()
                copy.Parent = target.Character or target
                copy.Disabled = false
            end
        end
        
        task.wait(0.1)
        container:Destroy()
    end)
    
    return success
end

