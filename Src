-- BUNNY HOP
function Hacks:bunny_hop()
    if self.active.bunny_hop then
        self.active.bunny_hop = false
        if self.bunny_hop_function then
            self.bunny_hop_function()
            self.bunny_hop_function = nil
        end
        return false
    end
    
    self.active.bunny_hop = true
    local running = true
    
    self.bunny_hop_function = function()
        running = false
        self.active.bunny_hop = false
        self.bunny_hop_function = nil
    end
    
    coroutine.wrap(function()
        local uis = game:GetService("UserInputService")
        while running do
            local player = game.Players.LocalPlayer
            local char = player.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                if humanoid and uis:IsKeyDown(Enum.KeyCode.Space) then
                    humanoid.Jump = true
                    task.wait(0.05)
                    humanoid.Jump = false
                end
            end
            task.wait(0.01)
        end
    end)()
    
    return self.bunny_hop_function
end

