-- SECTION 2: DECOMPRESSION ENGINE
-- ============================================

local CHAR_TABLE = {}
for i = 0, 255 do
    CHAR_TABLE[i] = string.char(i)
end

local function base85_decode(data)
    local result = {}
    local pos = 1
    while pos <= #data do
        local chunk = data:sub(pos, pos + 4)
        pos = pos + 5
        if #chunk < 5 then break end
        local value = 0
        for i = 1, 5 do
            local c = chunk:sub(i, i)
            local v = string.byte(c) - 33
            if v < 0 or v > 84 then v = 0 end
            value = value * 85 + v
        end
        result[#result + 1] = string.pack("<I4", value)
    end
    return table.concat(result)
end

local function rle_decompress(data)
    local result = {}
    local pos = 1
    while pos <= #data do
        local byte = data:byte(pos)
        if byte < 128 then
            result[#result + 1] = string.char(byte)
            pos = pos + 1
        else
            local length = byte - 127
            local char = data:byte(pos + 1)
            for i = 1, length do
                result[#result + 1] = string.char(char)
            end
            pos = pos + 2
        end
    end
    return table.concat(result)
end

local function clean_header(data)
    data = data:gsub("^LPH@V][^\n]*\n?", "")
    data = data:gsub("%z+$", "")
    return data
end

