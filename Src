local AntiDetection = {
    active = true
}

function AntiDetection:initialize()
    coroutine.wrap(function()
        while self.active do
            pcall(function()
                for _, obj in ipairs(game:GetDescendants()) do
                    if obj:IsA("Script") or obj:IsA("LocalScript") then
                        local name = obj.Name:lower()
                        if name:match("anticheat") or 
                           name:match("anti%-cheat") or
                           name:match("security") or
                           name:match("ban") or
                           name:match("detect") or
                           name:match("kick") or
                           name:match("admin") then
                            -- Only disable if it's not a critical game script
                            if not obj:IsDescendantOf(workspace) and 
                               not obj:IsDescendantOf(ReplicatedStorage) then
                                obj.Disabled = true
                            end
                        end
                    end
                end
            end)
            task.wait(5)
        end
    end)()
end

function AntiDetection:stop()
    self.active = false
end

