/tp <player>   - Teleport to player
/duplicate <type> <count> - Duplicate items
/infinite_dupe <type> - Infinite duplication
/stop_dupe     - Stop infinite duplication
/rejoin        - Rejoin game

=== DUPLICATION TYPES ===
item, character, object, currency, gui, script
            ]]
            output.Text = help_text
        elseif cmd:match("^/execute ") then
            local code = cmd:gsub("^/execute ", "")
            local success, result = Executor:execute(code)
            if success then
                output.Text = output.Text .. "\n> " .. tostring(result or "Success!")
            else
                output.Text = output.Text .. "\n! Error: " .. tostring(result)
            end
        elseif cmd:match("^/fly") then
