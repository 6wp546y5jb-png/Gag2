        if part:IsA("BasePart") and part.Transparency < 1 then
            changed[part] = part.Transparency
            part.Transparency = 0.3
        end
    end
    
    self.functions.wallhack = function()
        for part, transparency in pairs(changed) do
            if part then
                part.Transparency = transparency
            end
        end
        self.active.wallhack = false
        self.functions.wallhack = nil
    end
    
    return self.functions.wallhack
end

