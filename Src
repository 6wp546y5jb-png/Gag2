            output.Text = output.Text .. "\n> Speed hack enabled (x" .. mult .. ")"
        elseif cmd:match("^/esp") then
            Hacks:esp(Color3.fromRGB(255, 0, 0))
            output.Text = output.Text .. "\n> ESP enabled"
        elseif cmd:match("^/killall") then
            local killed = Hacks:kill_all()
            output.Text = output.Text .. "\n> Killed: " .. table.concat(killed, ", ")
        elseif cmd:match("^/god") then
            Hacks:god_mode()
            output.Text = output.Text .. "\n> God mode enabled"
        elseif cmd:match("^/noclip") then
            Hacks:no_clip()
            output.Text = output.Text .. "\n> No clip enabled"
        elseif cmd:match("^/teleport ") then
            local x, y, z = cmd:match("(%d+)[, ]*(%d+)[, ]*(%d+)")
            if x and y and z then
                Hacks:teleport(Vector3.new(tonumber(x), tonumber(y), tonumber(z)))
                output.Text = output.Text .. "\n> Teleported to " .. x .. ", " .. y .. ", " .. z
            end
        elseif cmd:match("^/tp ") then
            local name = cmd:gsub("^/tp ", "")
            Hacks:teleport_to_player(name)
            output.Text = output.Text .. "\n> Teleported to " .. name
        elseif cmd:match("^/duplicate ") then
            local type, count = cmd:match("^/duplicate (%w+) (%d+)")
            if type then
                count = tonumber(count) or 1
                Duplicator:duplicate(game.Players.LocalPlayer, type, count)
                output.Text = output.Text .. "\n> Duplicated " .. count .. " " .. type .. "(s)"
            end
        elseif cmd:match("^/infinite_dupe ") then
            local type = cmd:gsub("^/infinite_dupe ", "")
            Duplicator:start_infinite_duplication(type)
            output.Text = output.Text .. "\n> Infinite duplication started for " .. type
        elseif cmd:match("^/stop_dupe") then
            output.Text = output.Text .. "\n> Use the stop function returned from start_infinite_duplication"
        elseif cmd:match("^/rejoin") then
            AntiDetection:rejoin()
            output.Text = output.Text .. "\n> Rejoining..."
        else
            output.Text = output.Text .. "\n! Unknown command. Type /help for commands"
        end
    end
    
