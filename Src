                    if closest then
                        local cam = workspace.CurrentCamera
                        if cam then
                            cam.CFrame = CFrame.new(cam.CFrame.Position, closest.Position)
                        end
                    end
                end
            end
            task.wait(0.05)
        end
    end)()
    
    return self.functions.aimbot
