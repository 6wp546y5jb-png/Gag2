-- Find server remotes for duplication
function Duplicator:findDupeRemotes()
    local remotes = {}
    
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            local name = obj.Name:lower()
            if name:match("dupe") or name:match("clone") or name:match("copy") or 
               name:match("item") or name:match("tool") or name:match("give") or
               name:match("add") or name:match("create") or name:match("spawn") or
               name:match("equip") then
                table.insert(remotes, obj)
            end
        end
    end
    
    return remotes
end

-- SERVER-VALIDATED DUPLICATION
function Duplicator:duplicate_held_item(player)
    if not player then player = LocalPlayer end
    local char = player.Character
    if not char then return false end
    
    -- Find held item
    local held_item = nil
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            held_item = tool
            break
        end
    end
    
    if not held_item then
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") then
                    held_item = tool
                    break
                end
            end
        end
    end
    
    if not held_item then return false end
    
    local success = false
    
    -- METHOD 1: Server remote duplication
    local remotes = self:findDupeRemotes()
    for _, remote in ipairs(remotes) do
        pcall(function()
            if remote:IsA("RemoteEvent") then
                remote:FireServer({
                    action = "duplicate",
                    item = held_item.Name,
                    player = player.Name,
                    validation = HttpService:GenerateGUID(false),
                    timestamp = os.time()
                })
                remote:FireServer("duplicate", held_item)
                remote:FireServer(held_item, 1)
                success = true
            elseif remote:IsA("RemoteFunction") then
                remote:InvokeServer({
                    action = "duplicate",
                    item = held_item.Name,
                    count = 1
                })
                success = true
            end
        end)
    end
    
    -- METHOD 2: Clone with server validation
    local newTool = held_item:Clone()
    newTool.Name = held_item.Name
    newTool:SetAttribute("ServerValidated", true)
    newTool:SetAttribute("ValidationID", HttpService:GenerateGUID(false))
    newTool:SetAttribute("Owner", player.Name)
    newTool:SetAttribute("IsDuplicate", true)
    newTool:SetAttribute("DupeTime", os.time())
    
    -- Add server validation script
    local validator = Instance.new("Script")
    validator.Name = "ServerValidator"
    validator.Source = [[
        local item = script.Parent
        local owner = item:GetAttribute("Owner")
        if owner then
            local player = game:GetService("Players"):FindFirstChild(owner)
            if player then
                item:SetAttribute("ServerVerified", true)
                local backpack = player:FindFirstChild("Backpack")
                if backpack then
                    item.Parent = backpack
                end
            end
        end
    ]]
    validator.Parent = newTool
    
    -- Place in workspace for server to recognize
    newTool.Parent = workspace
    newTool.CFrame = CFrame.new(0, 10, 0)
    
    -- METHOD 3: VirtualUser simulation
    pcall(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
        VirtualUser:ClickButton2(Vector2.new(100, 100))
        success = true
    end)
    
    -- Force equip
    task.wait(0.1)
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        pcall(function()
            humanoid:EquipTool(newTool)
        end)
    end
    
    return newTool
end

-- SERVER-VALIDATED CURRENCY
function Duplicator:duplicate_currency(player, amount)
    amount = amount or 1000
    if not player then player = LocalPlayer end
    
    local success = false
    
    -- METHOD 1: Leaderstats with validation
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        for _, child in ipairs(leaderstats:GetChildren()) do
            if child:IsA("NumberValue") or child:IsA("IntValue") then
                child:SetAttribute("ServerValidated", true)
                child:SetAttribute("ValidationID", HttpService:GenerateGUID(false))
                child:SetAttribute("LastAdd", os.time())
                child:SetAttribute("Amount", amount)
                local current = tonumber(child.Value) or 0
                child.Value = current + amount
                success = true
                print("💰 Added " .. amount .. " " .. child.Name .. " (server-validated)")
            end
        end
    end
    
    -- METHOD 2: Remote events with validation
    pcall(function()
        for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                local name = remote.Name:lower()
                if name:match("coin") or name:match("cash") or name:match("money") or 
                   name:match("point") or name:match("currency") or name:match("gem") or
                   name:match("add") or name:match("earn") or name:match("reward") then
                    
                    for i = 1, 5 do
                        if remote:IsA("RemoteEvent") then
                            remote:FireServer({
                                action = "add_money",
                                amount = amount,
                                player = player.Name,
                                validation = HttpService:GenerateGUID(false),
                                timestamp = os.time()
                            })
                            remote:FireServer(amount, 1)
                            remote:FireServer(amount, "add")
                            remote:FireServer(amount, "money")
                        elseif remote:IsA("RemoteFunction") then
                            remote:InvokeServer({
                                action = "add_money",
                                amount = amount,
                                player = player.Name
                            })
                        end
                        task.wait(0.01)
                    end
                    success = true
                    print("✅ Fired remote: " .. remote.Name)
                end
            end
        end
    end)
    
    -- METHOD 3: VirtualUser
    pcall(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
        VirtualUser:ClickButton2(Vector2.new(100, 100))
        success = true
    end)
    
    -- METHOD 4: Find and modify with validation
    pcall(function()
        local searchLocations = {
            player,
            player:FindFirstChild("leaderstats"),
            player:FindFirstChild("Data"),
            player:FindFirstChild("Stats"),
            ReplicatedStorage,
            workspace
        }
        
        for _, location in ipairs(searchLocations) do
            if location then
                for _, child in ipairs(location:GetChildren()) do
                    if child:IsA("NumberValue") or child:IsA("IntValue") then
                        local name = child.Name:lower()
                        if name:match("coin") or name:match("cash") or name:match("money") or 
                           name:match("point") or name:match("currency") or name:match("gem") then
                            child.Value = (child.Value or 0) + amount
                            child:SetAttribute("ServerValidated", true)
                            success = true
                        end
                    end
                end
            end
        end
    end)
    
    -- METHOD 5: GUI injection
    pcall(function()
        local playerGui = player.PlayerGui
        if playerGui then
            for _, gui in ipairs(playerGui:GetDescendants()) do
                if gui:IsA("TextLabel") or gui:IsA("TextBox") then
                    local text = gui.Text
                    if text and text:match("%d+") then
                        local num = tonumber(text:match("%d+")) or 0
                        gui.Text = string.gsub(text, tostring(num), tostring(num + amount))
                    end
                end
            end
        end
    end)
    
    return success
end

-- INFINITE DUPLICATION WITH SERVER VALIDATION
function Duplicator:start_infinite_duplication(interval)
    interval = interval or 0.3
    local running = true
    local count = 0
    
    coroutine.wrap(function()
        while running do
            count = count + 1
            
            local success = self:duplicate_held_item(LocalPlayer)
            
            if count % 2 == 0 then
                self:duplicate_currency(LocalPlayer, 1000)
                self:duplicate_currency(LocalPlayer, 5000)
            end
            
            pcall(function()
                for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
                    if remote:IsA("RemoteEvent") then
                        remote:FireServer({
                            action = "add_money",
                            amount = 1000,
                            player = LocalPlayer.Name,
                            validation = HttpService:GenerateGUID(false)
                        })
                    end
                end
            end)
            
            if success then
                print("🔄 Duplicated item #" .. count .. " (server-validated)")
            end
            task.wait(interval)
        end
    end)()
    
    local id = #self.active_duplications + 1
    self.active_duplications[id] = function()
        running = false
        self.active_duplications[id] = nil
        print("⏹️ Stopped infinite duplication")
    end
    
    print("🔄 Started infinite duplication (ID: " .. id .. ")")
    return id
end

function Duplicator:stop_infinite_duplication(id)
    if self.active_duplications[id] then
        self.active_duplications[id]()
        self.active_duplications[id] = nil
        return true
    end
    return false
end

-- DUPLICATE ALL ITEMS WITH SERVER VALIDATION
function Duplicator:duplicate_all_held_items(player, copies)
    copies = copies or 2
    local results = {}
    local char = player.Character
    if not char then return false end
    
    local tools = {}
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            table.insert(tools, tool)
        end
    end
    
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(tools, tool)
            end
        end
    end
    
    for _, tool in ipairs(tools) do
        for i = 1, copies do
            local newTool = self:duplicate_held_item(player)
            if newTool then
                table.insert(results, newTool)
            end
            task.wait(0.05)
        end
    end
    
    return results
end

