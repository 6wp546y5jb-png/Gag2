        toggle.Size = UDim2.new(0, 50, 0, 25)
        toggle.Position = UDim2.new(0.75, 0, 0.5, -12.5)
        toggle.Text = "OFF"
        toggle.TextSize = 12
        toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
        toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        toggle.BorderSizePixel = 0
        toggle.Parent = frame
        
        local status = false
        
        toggle.MouseButton1Click:Connect(function()
            status = not status
            if status then
                toggle.Text = "ON"
                toggle.BackgroundColor3 = color
                toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
                if toggle_function then
                    local disable_func = toggle_function()
                    if disable_func then
                        -- Store disable function for later
                        local old_click = toggle.MouseButton1Click
                        toggle.MouseButton1Click:Connect(function()
                            if status then
                                disable_func()
                                status = false
                                toggle.Text = "OFF"
                                toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                            end
                        end)
                    end
                end
            else
                toggle.Text = "OFF"
                toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            end
        end)
        
        return toggle
    end
    
