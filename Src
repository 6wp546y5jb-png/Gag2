local function Toggle(Row, toggle_function, accent_color)
    accent_color = accent_color or Theme.Accent
    
    local Holder = Create("Frame",{
        AnchorPoint = Vector2.new(1,.5),
        Position = UDim2.new(1,0,.5,0),
        Size = UDim2.new(0,44,0,22),
        BackgroundColor3 = Theme.Secondary,
        BorderSizePixel = 0,
        Parent = Row
    })

    Corner(Holder,99)

    local Knob = Create("Frame",{
        Position = UDim2.new(0,2,0.5,-9),
        Size = UDim2.new(0,18,0,18),
        BackgroundColor3 = Theme.Secondary,
        BorderSizePixel = 0,
        Parent = Holder
    })

    Corner(Knob,99)
    
    local enabled = false
    
    local function update_state()
        if enabled then
            Holder.BackgroundColor3 = accent_color
            TweenService:Create(Knob, TweenInfo.new(.15), {
                Position = UDim2.new(1,-20,0.5,-9)
            }):Play()
            Knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
        else
            Holder.BackgroundColor3 = Theme.Secondary
            TweenService:Create(Knob, TweenInfo.new(.15), {
                Position = UDim2.new(0,2,0.5,-9)
            }):Play()
            Knob.BackgroundColor3 = Theme.Secondary
        end
    end
    
    local function toggle()
        enabled = not enabled
        update_state()
        
        if enabled then
            if toggle_function then
                local disable_func = toggle_function()
                if disable_func then
                    -- Store disable function to call when toggling off
                    local old_toggle = toggle
                    toggle = function()
                        disable_func()
                        enabled = false
                        update_state()
                        toggle = old_toggle
                    end
                end
            end
        end
    end
    
    Holder.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            toggle()
        end
    end)
    
    update_state()
    
    return Holder
end

local function Slider(Row, default_value, min, max, callback)
    min = min or 0
    max = max or 100
    default_value = default_value or 50
    
    local value_label = Create("TextLabel",{
        AnchorPoint = Vector2.new(1,.5),
        Position = UDim2.new(1,0,.5,0),
        Size = UDim2.new(0,40,0,20),
        BackgroundTransparency = 1,
        Text = tostring(default_value),
        TextColor3 = Theme.Accent,
        Font = Enum.Font.GothamBold,
        TextSize = 12,
        Parent = Row
    })

    local Bar = Create("Frame",{
        AnchorPoint = Vector2.new(1,.5),
        Position = UDim2.new(1,-50,.5,0),
        Size = UDim2.new(0,170,0,6),
        BackgroundColor3 = Theme.Secondary,
        BorderSizePixel = 0,
        Parent = Row
    })

    Corner(Bar,99)

    local Fill = Create("Frame",{
        Size = UDim2.new((default_value - min)/(max - min),0,1,0),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Parent = Bar
    })

    Corner(Fill,99)

    local Knob = Create("Frame",{
        AnchorPoint = Vector2.new(.5,.5),
        Position = UDim2.new(1,0,.5,0),
        Size = UDim2.new(0,12,0,12),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Parent = Fill
    })

    Corner(Knob,99)
    
    local dragging = false
    local current_value = default_value
    
    local function update_slider(input)
        local mouse_pos = input.Position.X
        local bar_abs_pos = Bar.AbsolutePosition.X
        local bar_width = Bar.AbsoluteSize.X
        
        local percent = math.clamp((mouse_pos - bar_abs_pos) / bar_width, 0, 1)
        current_value = math.floor(min + (max - min) * percent)
        
        Fill.Size = UDim2.new(percent,0,1,0)
        value_label.Text = tostring(current_value)
        
        if callback then
            callback(current_value)
        end
    end
    
    Bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update_slider(input)
        end
    end)
    
    Bar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update_slider(input)
        end
    end)
    
    return function() return current_value end
end

