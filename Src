-- FLY HACK
function Hacks:fly(speed)
    speed = speed or 50
    local char = LocalPlayer.Character
    if not char then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    if self.active.fly then
        self.active.fly = false
        if self.functions.fly then
            self.functions.fly()
            self.functions.fly = nil
        end
        return false
    end
    
    self.active.fly = true
    local flying = true
    local originalGravity = workspace.Gravity
    workspace.Gravity = 0
    hrp.Anchored = false
    
    self.functions.fly = function()
        flying = false
        workspace.Gravity = originalGravity
        self.active.fly = false
        self.functions.fly = nil
    end
    
    coroutine.wrap(function()
        while flying do
            if humanoid then
                humanoid.PlatformStand = true
            end
            
            local move_dir = Vector3.new()
            local camera = workspace.CurrentCamera
            
            if camera then
                local lookVector = camera.CFrame.LookVector
                local rightVector = camera.CFrame.RightVector
                
                if UIS:IsKeyDown(Enum.KeyCode.W) then
                    move_dir = move_dir + Vector3.new(lookVector.X, 0, lookVector.Z)
                end
                if UIS:IsKeyDown(Enum.KeyCode.S) then
                    move_dir = move_dir - Vector3.new(lookVector.X, 0, lookVector.Z)
                end
                if UIS:IsKeyDown(Enum.KeyCode.A) then
                    move_dir = move_dir - Vector3.new(rightVector.X, 0, rightVector.Z)
                end
                if UIS:IsKeyDown(Enum.KeyCode.D) then
                    move_dir = move_dir + Vector3.new(rightVector.X, 0, rightVector.Z)
                end
                if UIS:IsKeyDown(Enum.KeyCode.Space) then
                    move_dir = move_dir + Vector3.new(0, 1, 0)
                end
                if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
                    move_dir = move_dir - Vector3.new(0, 1, 0)
                end
            end
            
            if move_dir.Magnitude > 0 then
                move_dir = move_dir.Unit * speed
                hrp.Velocity = move_dir
            else
                hrp.Velocity = Vector3.new(0, 0, 0)
            end
            
            task.wait()
        end
        if humanoid then
            humanoid.PlatformStand = false
        end
    end)()
    
    return self.functions.fly
end

-- SPEED HACK (FIXED)
function Hacks:speed(multiplier)
    multiplier = multiplier or 2
    local char = LocalPlayer.Character
    if not char then return false end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return false end
    
    if self.active.speed then
        -- Update the speed multiplier instead of toggling off
        if humanoid then
            local baseSpeed = 16 -- Default walkspeed
            humanoid.WalkSpeed = baseSpeed * multiplier
            currentSpeedMultiplier = multiplier
            return self.functions.speed
        end
    end
    
    self.active.speed = true
    local original = humanoid.WalkSpeed
    
    self.functions.speed = function()
        if humanoid then
            humanoid.WalkSpeed = original
        end
        self.active.speed = false
        self.functions.speed = nil
    end
    
    humanoid.WalkSpeed = original * multiplier
    currentSpeedMultiplier = multiplier
    return self.functions.speed
end

