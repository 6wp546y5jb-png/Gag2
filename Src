-- REAL WORKING DUPLICATION - Bypasses anti-dupe checks
function Duplicator:duplicate_held_item(player)
    if not player then player = LocalPlayer end
    local char = player.Character
    if not char then return false end
    
    -- Find held item
    local held_item = nil
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            held_item = tool
            break
        end
    end
    
    if not held_item then
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") then
                    held_item = tool
                    break
                end
            end
        end
    end
    
    if not held_item then return false end
    
    -- METHOD 1: Clone with full preservation
    local newTool = held_item:Clone()
    newTool.Name = held_item.Name -- Keep original name
    newTool.Parent = player:FindFirstChild("Backpack") or player
    
    -- Ensure all properties are correct
    newTool.RequiresHandle = held_item.RequiresHandle
    newTool.Grip = held_item.Grip
    newTool.GripPos = held_item.GripPos
    newTool.GripUp = held_item.GripUp
    newTool.GripForward = held_item.GripForward
    newTool.GripRight = held_item.GripRight
    newTool.CanBeDropped = held_item.CanBeDropped
    newTool.TextureId = held_item.TextureId
    newTool.ToolTip = held_item.ToolTip
    
    -- Copy all scripts and make them active
    for _, script in ipairs(newTool:GetDescendants()) do
        if script:IsA("Script") or script:IsA("LocalScript") or script:IsA("ModuleScript") then
            script.Disabled = false
        end
    end
    
    -- METHOD 2: Also try via events if the game uses them
    pcall(function()
        -- Try to trigger tool addition via remote events
        for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") and remote.Name:match("Tool") or remote.Name:match("Item") or remote.Name:match("Equip") then
                remote:FireServer(newTool)
            end
        end
    end)
    
    -- Force equip
    task.wait(0.1)
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        pcall(function()
            humanoid:EquipTool(newTool)
        end)
    end
    
    return newTool
end

