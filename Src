local Executor = {
    version = "3.2.1",
    features = {},
    loaded_scripts = {},
    active_hacks = {}
}

function Executor:execute(script_code)
    local success, result = pcall(function()
        local chunk = loadstring(script_code)
        if chunk then
            return chunk()
        end
        return nil
    end)
    return success, result
end

function Executor:inject_script(player, script_content)
    if not player or not script_content then
        return false
    end
    
    local success = pcall(function()
        local container = Instance.new("LocalScript")
        container.Name = "Injected_" .. os.time()
        container.Source = script_content
        
        if player.Character then
            container.Parent = player.Character
        else
            container.Parent = player
        end
        
        container.Disabled = false
        task.wait(0.5)
        container:Destroy()
    end)
    
    return success
end

