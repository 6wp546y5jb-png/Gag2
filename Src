        TextColor3 = Theme.Text,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Box
    })

    Create("TextLabel",{
        AnchorPoint = Vector2.new(1,.5),
        Position = UDim2.new(1,-8,.5,0),
        Size = UDim2.new(0,12,1,0),
        BackgroundTransparency = 1,
        Text = "▼",
        TextColor3 = Theme.Accent,
        Font = Enum.Font.GothamBold,
        TextSize = 10,
        Parent = Box
    })
    
    local expanded = false
    local dropdown_menu = nil
    
    local function toggle_dropdown()
        expanded = not expanded
        
        if expanded then
            dropdown_menu = Create("Frame",{
                AnchorPoint = Vector2.new(1,0),
                Position = UDim2.new(1,0,0,30),
                Size = UDim2.new(0,150,0,math.min(#options * 30, 150)),
                BackgroundColor3 = Theme.Card,
                BorderSizePixel = 0,
                ZIndex = 10,
                Parent = Box
            })
            Corner(dropdown_menu,8)
            Stroke(dropdown_menu)
            
            local layout = Create("UIListLayout",{
                Padding = UDim.new(0,2),
                Parent = dropdown_menu
            })
            
            for i, option in ipairs(options) do
                local btn = Create("TextButton",{
                    Size = UDim2.new(1,0,0,28),
                    BackgroundTransparency = 1,
                    Text = option,
                    TextColor3 = Theme.Text,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    AutoButtonColor = false,
                    Parent = dropdown_menu
                })
                
                btn.MouseEnter:Connect(function()
                    btn.BackgroundTransparency = 0.1
                    btn.BackgroundColor3 = Theme.Accent
                end)
                
                btn.MouseLeave:Connect(function()
                    btn.BackgroundTransparency = 1
                end)
                
                btn.MouseButton1Click:Connect(function()
                    Label.Text = option
                    if callback then callback(option, i) end
                    toggle_dropdown()
                end)
            end
        else
            if dropdown_menu then
                dropdown_menu:Destroy()
                dropdown_menu = nil
            end
        end
    end
    
    Box.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            toggle_dropdown()
        end
    end)
    
    return function() return Label.Text end
end

