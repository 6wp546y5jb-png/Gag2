local AntiDetection = {
    active = true
}

function AntiDetection:initialize()
    -- Run anti-detection measures immediately
    self:disable_anti_cheat()
    self:spoof_client()
    self:bypass_ban()
    
    -- Continuously protect
    coroutine.wrap(function()
        while self.active do
            task.wait(5)
            self:disable_anti_cheat()
            self:spoof_client()
        end
    end)()
end

function AntiDetection:bypass_ban()
    local success = pcall(function()
        local player = game.Players.LocalPlayer
        
        for _, service in ipairs(game:GetChildren()) do
            if service:IsA("DataStore") then
                service:Clear()
            end
        end
        
        local leaderstats = player:FindFirstChild("leaderstats")
        if leaderstats then
            for _, stat in ipairs(leaderstats:GetChildren()) do
                if stat:IsA("NumberValue") or stat:IsA("IntValue") then
                    if stat.Value > 0 then
                        stat.Value = stat.Value
                    end
                end
            end
        end
        
        return true
    end)
    return success
end

function AntiDetection:disable_anti_cheat()
    local disabled = {}
    
    for _, obj in ipairs(game:GetDescendants()) do
        if obj:IsA("Script") or obj:IsA("LocalScript") then
            local name = obj.Name:lower()
            if name:match("anticheat") or 
               name:match("anti%-cheat") or
               name:match("security") or
               name:match("ban") or
               name:match("detect") or
               name:match("kick") or
               name:match("admin") then
                obj.Disabled = true
                table.insert(disabled, obj)
            end
        end
    end
    
    return disabled
end

function AntiDetection:spoof_client()
    local success = pcall(function()
        local network = game:GetService("NetworkClient")
        network:SetVersion("0.0.0")
        
        local stats = game:GetService("Stats")
        stats:SetPing(0)
        
        return true
    end)
    return success
end

function AntiDetection:rejoin()
    local player = game.Players.LocalPlayer
    game:GetService("TeleportService"):Teleport(game.PlaceId, player)
    return true
end

function AntiDetection:stop()
    self.active = false
end

