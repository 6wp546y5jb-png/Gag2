local function Create(class,props,parent)
    local obj = Instance.new(class)
    for k,v in pairs(props or {}) do
        obj[k]=v
    end
    obj.Parent = parent
    return obj
end

local function Corner(obj,r)
    Create("UICorner",{CornerRadius=UDim.new(0,r)},obj)
end

local function Stroke(obj)
