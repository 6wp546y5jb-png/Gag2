-- SECTION 7: SCRIPT LOADER
-- ============================================

local ScriptLoader = {}

function ScriptLoader:load_from_url(url)
    local success, content = pcall(function()
        return game:GetService("HttpService"):GetAsync(url)
    end)
    if success and content then
        return Executor:execute(content)
    end
    return nil
end

function ScriptLoader:load_from_string(script_string)
    if script_string and type(script_string) == "string" then
        return Executor:execute(script_string)
    end
    return nil
end

function ScriptLoader:load_from_workspace(script_name)
    local found_script = nil
    for _, obj in ipairs(game:GetDescendants()) do
        if (obj:IsA("Script") or obj:IsA("LocalScript")) and obj.Name == script_name then
            found_script = obj
            break
        end
    end
    if found_script then
        return Executor:execute(found_script.Source)
    end
    return nil
end

function ScriptLoader:load_from_file(path)
    local success, content = pcall(function()
        return readfile(path)
    end)
    if success and content then
        return Executor:execute(content)
    end
    return nil
end

